rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Опционально после включения App Check на всех клиентах (см. docs/RUNBOOK.md, src/firebase/config.ts):
    //   allow read, write: if request.auth != null && request.auth.uid == userId && request.app != null;
    // Пока не включайте в проде, пока не убедитесь, что Web SDK отдаёт валидный App Check token.

    // --- Production: пользователь только со своими данными ---
    match /users/{userId}/nodes/{nodeId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/settings/{settingsId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // sync_meta, security/config, журнал изменений — всё в users/{uid}/security/{docId}
    match /users/{userId}/security/{document} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

/*
================================================================================
РЕЖИМ ОБСЛУЖИВАНИЯ — временно отключить всю БД (данные не удаляются)

1. В Firebase Console → Firestore → Rules замените содержимое service-блока
   на вариант ниже (или скопируйте весь файл, раскомментировав только нижний блок).

2. Опубликуйте правила (Publish) или из CLI:
   firebase deploy --only firestore:rules

3. Чтобы снова включить доступ — верните файл к варианту «Production» выше.

--------------------------------------------------------------------------------
// Замените тело service cloud.firestore на это:

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

================================================================================
*/
