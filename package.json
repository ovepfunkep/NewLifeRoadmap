  "type": "module",
  "scripts": {
    "dev": "node scripts/gen-app-version.mjs && vite",
    "build": "node scripts/gen-app-version.mjs && tsc && vite build && node scripts/postbuild-gh-pages.mjs",
    "build:gh-pages": "GITHUB_PAGES_BASE=/NewLifeRoadmap/ npm run build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "verify": "npm run test:ci && npm run build"
  },
  "dependencies": {
