# Firebase Configuration
# РџРѕР»СѓС‡РёС‚Рµ СЌС‚Рё Р·РЅР°С‡РµРЅРёСЏ РёР· Firebase Console: Project Settings в†’ General в†’ Your apps
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Опционально: Firebase App Check (reCAPTCHA v3 site key из Console → App Check → Web app)
# VITE_FIREBASE_APP_CHECK_RECAPTCHA_SITE_KEY=
# Локально: зарегистрируйте debug token в Console, затем задайте строку (или true для авто-токена в консоли)
# VITE_APP_CHECK_DEBUG_TOKEN=

# Опционально: ошибки в Sentry (без PII; см. src/main.tsx beforeSend)
# VITE_SENTRY_DSN=
